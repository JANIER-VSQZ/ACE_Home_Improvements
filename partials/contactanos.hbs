<section class="contact-card">
  <h2 data-i18n="contacto.titulo">Contáctanos</h2>
  <p class="contact-description" data-i18n="contacto.descripcion">¿Tienes alguna duda o comentario? Completa el formulario y te responderemos pronto.</p>

  <form class="contact-card__form" action="/enviar-contacto" method="POST">
    <div class="form-group">
      <label for="nombre" data-i18n="contacto.labelNombre">Nombre completo:</label>
      <input type="text" id="nombre" name="nombre" required />
    </div>

    <div class="form-group">
      <label for="correo" data-i18n="contacto.labelCorreo">Correo electrónico:</label>
      <input type="email" id="correo" name="correo" required />
    </div>

    <div class="form-group">
      <label for="mensaje" data-i18n="contacto.labelMensaje">Mensaje:</label>
      <textarea id="mensaje" name="mensaje" rows="4" required></textarea>
    </div>

    <button type="submit" class="send-btn" data-i18n="contacto.boton">Enviar mensaje</button>
  </form>
</section>
 

